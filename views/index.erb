<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-sRIl4kxILFvY47J16cr9ZwB07vP4J8+LH7qKQnuqkuIAvNWLzeN8tE5YBujZqJLB" crossorigin="anonymous">
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js" integrity="sha384-FKyoEForCGlyvwx9Hj09JcYn3nv7wiPVlz7YYwJrWVcXK/BmnVDxM+D2scQbITxI" crossorigin="anonymous"></script>
    <title>Document</title>
</head>
<body>
    <div class="container mt-4">
        <h1 class="mb-4">Ma Cave à Vin</h1>

        <div class="row">
            <!-- Colonne gauche : Consommation d'un vin -->
            <div class="col-md-6">
            <div class="card mb-4">
                <div class="card-header bg-primary text-white">
                <h5>Consommer un vin</h5>
                </div>
                <div class="card-body">
                <form action="/search/consume" method="get">
                    <div class="input-group mb-3">
                        <select class="form-select" name="searchType" aria-label="Default select example">
                            <option value="appelation" selected>rechercher l'appelation</option>
                            <option value="robe">rechercher la robe</option>
                            <option value="region">rechercher la région</option>
                            <option value="domaine">rechercher le domaine</option>
                        </select>
                    </div>
                    <div class="input-group mb-3">
                    <input
                        type="text"
                        class="form-control"
                        name="query"
                        placeholder="Rechercher une bouteille..."
                        aria-label="Rechercher une bouteille"
                    >
                    <button class="btn btn-outline-secondary" type="submit">
                        <i class="bi bi-search"></i> Rechercher
                    </button>
                    </div>
                </form>
                <!-- Zone pour afficher les résultats de recherche ou les vins disponibles -->
                <div id="wine-results" class="mt-3">
                </div>
                </div>
            </div>
            </div>

            <!-- Colonne droite : Ajouter un vin -->
            <div class="col-md-6">
            <div class="card">
                <div class="card-header bg-success text-white">
                <h5>Ajouter une bouteille</h5>
                </div>
                <div class="card-body">
                    <form action="/search/add" method="get">
                        <div class="input-group mb-3">
                            <input
                                type="text"
                                class="form-control"
                                name="appelation"
                                placeholder="Rentrer l'appelation de la bouteille..."
                                aria-label="Rentrer l'appelation de la bouteille"
                            >
                        </div>
                        <div class="input-group mb-3">
                            <input
                                type="number"
                                class="form-control"
                                name="annee"
                                placeholder="Rentrer l'année de la bouteille..."
    
                            >
                        </div>
                        <button class="btn btn-outline-secondary" type="submit">
                            <i class="bi bi-search"></i> Rechercher
                        </button>
                    </form>
                </div>
            </div>
            </div>
        </div>
    </div>
    <% if listeVins != nil %>
        <div class="card mx-5 mt-4">
            <div class="card-body">
                <table class="table table-striped">
                    <thead>
                        <tr>
                            <th scope="col">robe</th>
                            <th scope="col">région</th>
                            <th scope="col">appelation</th>
                            <th scope="col">domaine</th>
                            <th scope="col">année</th>
                            <th scope="col">nombre de bouteilles</th>
                            <th scope="col">actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% listeVins.each do |vin| %>
                            <tr>
                                <td><%= vin["robe"] %></td>
                                <td><%= vin["region"] %></td>
                                <td><%= vin["appelation"] %></td>
                                <td><%= vin["domaine"] %></td>
                                <td><%= vin["annee"] %></td>
                                <td><%= vin["nbBouteilles"] %></td>
                                <td>
                                    <form action="/changequantity/<%= action == "add" %>" method="post">
                                        <div class="input-group mb-3">
                                            <input type="number" name="nbBouteilles" class="form-control" value=1 size=4>
                                            <button class="btn <%= action == "add" ? 'btn-success' : 'btn-warning'%> btn-sm" id="basic-addon2">
                                                <%= action == "add" ? 'ajouter' : 'consommer'%>
                                            </button>
                                        </div>
                                        <input value=<%= vin["id"] %> name="vinId" type="hidden" />
                                    </form>
                                </td>
                            </tr>
                        <% end %>
                    </tbody>
                </table>
            </div>
        </div>
    <% end %>

    <% if action === 'add' %>
        <div class="card mx-5 mt-4">
            <div class="card-body">
                <h4>Si vous ne trouvez pas votre bouteille parmis celles existantes, ajoutez en une :</h4>
                <div class="card-body">
                    <form action="/new" method="post">
                        <div class="input-group mb-3">
                            <input
                                type="text"
                                class="form-control"
                                name="robe"
                                placeholder="robe"
                                required
                            >
                        </div>
                        <div class="input-group mb-3">
                            <input
                                type="text"
                                class="form-control"
                                name="region"
                                placeholder="région"
                                required
                            >
                        </div>
                        <div class="input-group mb-3">
                            <input
                                type="text"
                                class="form-control"
                                name="appelation"
                                placeholder="appelation"
                                aria-label="Rentrer l'appelation de la bouteille"
                                value="<%= nouveauVin[:appelation] %>"
                                required
                            >
                        </div>
                        <div class="input-group mb-3">
                            <input
                                type="text"
                                class="form-control"
                                name="domaine"
                                placeholder="domaine"
                                required
                            >
                        </div>
                        <div class="input-group mb-3">
                            <input
                                type="number"
                                class="form-control"
                                name="annee"
                                placeholder="année"
                                value=<%= nouveauVin[:annee] %>
                                required
                            >
                        </div>
                        <div class="input-group mb-3">
                            <input
                                type="number"
                                class="form-control"
                                name="nbBouteilles"
                                placeholder="quantité"
                                value=1
                                required
                            >
                        </div>
                        <button class="btn btn-outline-success" type="submit">
                            <i class="bi bi-search"></i> Créer
                        </button>
                    </form>
                </div>
            </div>
        </div>
    <% end %>
</body>
</html>